# ─────────────────────────────────────────────────────────────────────────────
# Azure OpenAI — required for vision extraction
# ─────────────────────────────────────────────────────────────────────────────
AZURE_OPENAI_API_KEY=<your-azure-openai-api-key>
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=<your-deployment-name>
AZURE_OPENAI_API_VERSION=2025-04-01-preview

# Optional: second deployment with GPT5_4 naming alias
AZURE_OPENAI_API_KEY_GPT5_4=
AZURE_OPENAI_ENDPOINT_GPT5_4=
AZURE_OPENAI_DEPLOYMENT_NAME_GPT5_4=
AZURE_OPENAI_API_VERSION_GPT5_4=

# ─────────────────────────────────────────────────────────────────────────────
# Azure Document Intelligence — required for OCR and page routing
# ─────────────────────────────────────────────────────────────────────────────
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_KEY=<your-document-intelligence-key>

# ─────────────────────────────────────────────────────────────────────────────
# App runtime
# ─────────────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────────────────────
# Token / cost controls
# ─────────────────────────────────────────────────────────────────────────────
OPENAI_CONCURRENCY=2
OPENAI_TIMEOUT_SECONDS=180
PDF_RENDER_DPI=180
MAX_IMAGE_WIDTH=1280
REPORT_IMAGE_WIDTH=1800
OCR_CONTEXT_MAX_CHARS=2600
VISION_ON_UNKNOWN_PAGES=true
FORCE_VISION_FOR_INSTRUMENTS=true
RETURN_DEBUG_PAGES=false
INCLUDE_REGISTER_ONLY_ITEMS=true

# ─────────────────────────────────────────────────────────────────────────────
# Optional: standard OpenAI fallback (Azure is preferred when Azure values set)
# ─────────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL_NAME=gpt-4o
